; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Just Coffee"
config/description="Psychological point-and-click adventure"
config/version="0.1.0"
run/main_scene="res://scenes/ui/boot.tscn"
config/features=PackedStringArray("4.7", "GL Compatibility")
config/icon="res://assets/ui/icon.svg"

[autoload]

EventBus="*res://core/event_bus.gd"
SaturationManager="*res://core/saturation_manager.gd"
CycleStateManager="*res://core/cycle_state_manager.gd"
InventoryManager="*res://core/inventory_manager.gd"
LocalizationManager="*res://core/localization_manager.gd"
GameFlags="*res://core/game_flags.gd"
Dialogic="*uid://ds2q0uclmolvu"
DialogicBridge="*res://core/dialogic_bridge.gd"
AudioSaturationController="*res://scripts/systems/audio_saturation_controller.gd"

[dialogic]

directories/dtl_directory={
"cycle_0/sample_greeting": "res://data/dialogues/en/cycle_0/sample_greeting.dtl",
"sample_greeting": "res://data/dialogues/fr/cycle_0/sample_greeting.dtl"
}
variables={
"cafe_spill_occurred": {
"type": 1,
"value": false
},
"current_cycle": {
"type": 2,
"value": 0
},
"current_district": {
"type": 0,
"value": "threshold"
},
"district_index": {
"type": 2,
"value": 0
},
"elena_gaze_complete": {
"type": 1,
"value": false
},
"inner_monologue_silent": {
"type": 1,
"value": false
},
"is_cafe_scene": {
"type": 1,
"value": false
},
"marc_apologized": {
"type": 1,
"value": false
},
"selected_outfit_id": {
"type": 0,
"value": ""
}
}
directories/dch_directory={}
layout/default_style="res://addons/dialogic/Modules/DefaultLayoutParts/Style_VN_Default/default_vn_style.tres"
layout/style_directory={
"": "res://addons/dialogic/Modules/DefaultLayoutParts/Style_VN_Default/default_vn_style.tres"
}

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[editor_plugins]

enabled=PackedStringArray("res://addons/dialogic/plugin.cfg")

